# editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{xml,gir}]
trim_trailing_whitespace = false
max_line_length = 1000

[*.{py,pyi}]
indent_size = 4

[*.{ts,tsx,js,svelte}]
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4
