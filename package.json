  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  },
  "dependencies": {
    "@lucide/svelte": "^0.514.0",
    "@smui/common": "link:/home/tomhodder/git/svelte-material-ui/packages/common",
    "@smui/tab": "link:/home/tomhodder/git/svelte-material-ui/packages/tab",
    "@smui/tab-bar": "link:/home/tomhodder/git/svelte-material-ui/packages/tab-bar",
    "bits-ui": "^2.6.0",
    "clsx": "^2.1.1",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.4.0",
    "tailwind-merge": "^3.3.1"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-svelte"
