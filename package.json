    "printWidth": 100,
    "tabWidth": 4,
    "useTabs": false,
    "svelteSortOrder": "options-scripts-markup-styles",
    "svelteStrictMode": true
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
