{
  "name": "remake_gallery",
  "version": "0.1.0",
  "type": "module",
  "description": "Simple SvelteKit app for portfolio/gallery",
  "private": true,
  "keywords": [
    "portfolio"
  ],
  "license": "MIT",
  "author": "",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "rimraf build .svelte-kit dist",
